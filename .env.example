# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=random-secret-string
# Bot @username (no @) — used to build miniapp deep links for visit broadcasts
TELEGRAM_BOT_USERNAME=
# Mini App short name configured in BotFather (defaults to "miniapp")
TELEGRAM_MINIAPP_SHORT_NAME=miniapp
# Chat ID of the group that receives "✅ {CM} visited {store}" broadcasts on visit lock
BROADCAST_CHAT_ID=
# Optional: separate chat for join-request approvals. Falls back to BROADCAST_CHAT_ID if unset.
JOIN_REQUEST_CHAT_ID=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Railway
WEBHOOK_DOMAIN=https://your-app.up.railway.app
PORT=3000

# Claude API (Phase 5 — leave empty until you have a key)
ANTHROPIC_API_KEY=

# Email (Phase 6 — leave empty until needed)
RESEND_API_KEY=
